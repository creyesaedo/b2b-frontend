# b2b-frontend — Next.js app (marketing landing + analytics product).
# Talks ONLY to the b2b-bff (single entry point). Runs on http://localhost:3000,
# which is the FRONTEND_URL the BFF allows via credentialed CORS.

# Base URL of the b2b-bff. Public (used by the browser) — never put secrets here.
NEXT_PUBLIC_BFF_URL=http://localhost:8002
